# Copy this file to .env for local development.
# Never commit real secrets.

NODE_ENV=development

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=careerpilot
POSTGRES_USER=careerpilot
POSTGRES_PASSWORD=careerpilot_dev_password

DATABASE_URL=postgres://careerpilot:careerpilot_dev_password@localhost:5432/careerpilot

BACKEND_PORT=3000
BACKEND_CORS_ORIGIN=http://localhost:4200
LOG_LEVEL=info

FRONTEND_PORT=4200
NG_APP_API_BASE_URL=http://localhost:3000/api/v1
