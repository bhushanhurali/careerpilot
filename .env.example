# Copy this file to .env at the repository root.
# Never commit .env or use these example secrets in production.

NODE_ENV=development

# PostgreSQL container initialization and host port.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=careerpilot
POSTGRES_USER=careerpilot
POSTGRES_PASSWORD=careerpilot_dev_password

# Used by host-run backend and migration commands.
# Docker Compose overrides the hostname to the postgres service inside containers.
DATABASE_URL=postgres://careerpilot:careerpilot_dev_password@localhost:5432/careerpilot

# Backend listener and the single browser origin allowed to send credentialed requests.
BACKEND_PORT=3000
BACKEND_CORS_ORIGIN=http://localhost:4200
LOG_LEVEL=info

# Use different, randomly generated secrets of at least 32 characters.
JWT_ACCESS_SECRET=replace-with-at-least-32-characters-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh-secret

# Token lifetimes in seconds: 15 minutes and 30 days by default.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# false permits local HTTP. Set true for production HTTPS.
COOKIE_SECURE=false

# Frontend dev-server host port and browser-visible API URL.
FRONTEND_PORT=4200
NG_APP_API_BASE_URL=http://localhost:3000/api/v1
