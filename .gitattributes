# Normalize text files to LF in the repository.
* text=auto eol=lf

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Configuration and data files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.env.example text eol=lf

# Documentation
*.md text eol=lf

# Shell and automation scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.ps1 text eol=lf
*.cmd text eol=lf

# Keep binary files binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
